{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "chunk_id",
    "language",
    "asr_clarity",
    "summary",
    "general_keywords",
    "film_keywords",
    "film_concepts",
    "film_terminology",
    "uncertainty_note",
    "needs_human_review"
  ],
  "properties": {
    "chunk_id": {
      "type": ["integer", "string"]
    },
    "language": {
      "type": "string",
      "minLength": 2,
      "maxLength": 16
    },
    "asr_clarity": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "summary": {
      "type": "string",
      "maxLength": 800
    },
    "general_keywords": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 40
      },
      "maxItems": 8
    },
    "film_keywords": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 40
      },
      "maxItems": 8
    },
    "film_concepts": {
      "type": "array",
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["concept", "confidence", "evidence"],
        "properties": {
          "concept": {
            "type": "string",
            "enum": [
              "acting",
              "directing",
              "cinematography",
              "mise_en_scene",
              "editing",
              "sound",
              "narrative",
              "genre",
              "character",
              "production",
              "distribution_exhibition",
              "audience_reception",
              "film_history",
              "ethics_politics"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "evidence": {
            "type": "string",
            "maxLength": 160
          }
        },
        "additionalProperties": false
      }
    },
    "film_terminology": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "object",
        "required": ["term", "status", "evidence"],
        "properties": {
          "term": {
            "type": "string",
            "maxLength": 50
          },
          "status": {
            "type": "string",
            "enum": ["explicit", "inferred"]
          },
          "evidence_type": {
            "type": "string",
            "enum": ["explicit", "inferred"]
          },
          "evidence": {
            "type": "string",
            "maxLength": 160
          }
        },
        "additionalProperties": false
      }
    },
    "uncertainty_note": {
      "type": "string",
      "maxLength": 180
    },
    "needs_human_review": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
